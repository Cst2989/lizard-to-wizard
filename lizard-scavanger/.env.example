# --- Sentry ---
# Public DSN for browser + server instrumentation
SENTRY_DSN=
VITE_SENTRY_DSN=
# Used to build deep-links to traces/issues
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=
# Secret used to verify inbound webhook signatures from Sentry
SENTRY_WEBHOOK_SECRET=

# --- Axiom ---
# Ingest token (write-only)
AXIOM_TOKEN=
# Dataset name (e.g., "scavenger-prod")
AXIOM_DATASET=
# Read-only token + dashboard URL for the L4 metrics view
AXIOM_QUERY_TOKEN=
AXIOM_DASHBOARD_URL=

# --- Workshop ---
# Random ~32-byte secret used to derive per-attendee keys
WORKSHOP_SECRET=dev-secret-change-me
# Shown on /about so attendees can log in to the shared tools
SHARED_SENTRY_LOGIN=
SHARED_AXIOM_LOGIN=

# --- Netlify (for Blobs from classic function runtime) ---
# Personal Access Token generated at:
# https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_PAT=
