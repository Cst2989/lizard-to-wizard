{
  "name": "microfrontends-demo",
  "version": "1.0.0",
  "description": "Webpack Module Federation demo with 4 vertical microfrontends",
  "private": true,
  "pnpm": {
    "workspaces": [
      "apps/*",
      "packages/*"
    ]
  },
  "scripts": {
    "dev": "pnpm -r --filter './apps/*' --parallel dev",
    "build": "pnpm -r build",
    "serve": "pnpm -r --parallel serve"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "babel-loader": "^9.1.3",
    "html-webpack-plugin": "^5.5.3",
    "ts-loader": "^9.5.0",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1"
  }
}
